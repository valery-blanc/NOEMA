# ─── NOÊMA — variables d'environnement (copier en .env, NE PAS committer) ───

# Postgres
POSTGRES_USER=noema
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=noema

# Payload
# Générer : openssl rand -hex 32
PAYLOAD_SECRET=change-me-32+chars-random-secret

# Hôtes publics (prod Avignon ; domaine définitif noema-library.ch quand acheté)
PUBLIC_HOST=noema.zitoon.com
ADMIN_HOST=noema-admin.zitoon.com
PUBLIC_SITE_URL=https://noema.zitoon.com

# Aperçu (preview) — site de prévisualisation protégé
PREVIEW_HOST=noema-preview.zitoon.com
PREVIEW_SITE_URL=https://noema-preview.zitoon.com
# Token interne CMS ↔ publisher (openssl rand -hex 24)
PUBLISH_TOKEN=change-me-internal-token
# Basic-auth Traefik de l'aperçu : htpasswd -nbB user 'motdepasse'
# ⚠️ Docker Compose interprète « $ » → DOUBLER chaque « $ » en « $$ » dans le hash.
PREVIEW_BASICAUTH=noema:$$2y$$05$$REMPLACER_PAR_LE_HASH

# Traefik (convention Avignon — réseau Docker externe partagé)
TRAEFIK_NETWORK=web
TRAEFIK_ENTRYPOINT=websecure
CERT_RESOLVER=letsencrypt
