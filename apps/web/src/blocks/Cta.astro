---
const { block } = Astro.props
---
<section class="cta-sec" data-reveal>
  <div class="wrap inner">
    <h2>{block.heading}</h2>
    {block.text && <p>{block.text}</p>}
    {block.buttonLabel && block.buttonHref && <a class="btn" href={block.buttonHref}>{block.buttonLabel}</a>}
  </div>
</section>

<style>
  .cta-sec { background: var(--c-petrol); color: var(--c-cream-text); padding-block: var(--pad-y); }
  .inner { max-inline-size: 46ch; }
  .cta-sec h2 { font-size: var(--fs-h2); color: #F4EFE2; margin: 0 0 .5em; }
  .cta-sec p { color: var(--c-sand, rgba(241,236,221,.7)); margin: 0 0 1.8rem; }
  .btn {
    display: inline-flex; padding: 14px 26px; border: 1px solid var(--c-gold-light); border-radius: 40px;
    font-family: var(--ff-mono); font-size: 11px; letter-spacing: .18em; text-transform: uppercase; color: #F6F1E6;
    transition: background .4s, color .4s;
  }
  .btn:hover { background: var(--c-gold-light); color: var(--c-petrol-deep); }
</style>
