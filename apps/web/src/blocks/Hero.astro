---
const { block } = Astro.props
---
<header class="hero" data-reveal>
  {block.eyebrow && <p class="eyebrow">{block.eyebrow}</p>}
  <h1>{block.heading}</h1>
  {block.intro && <p class="intro">{block.intro}</p>}
</header>

<style>
  .hero {
    margin-block-end: clamp(3rem, 9vw, 7rem);
    padding-block-start: clamp(1rem, 6vh, 4rem);
  }
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.28em;
    font-size: var(--fs-small);
    color: var(--c-brass);
    margin: 0 0 1.2rem;
  }
  .hero h1 {
    font-size: var(--fs-display);
    letter-spacing: 0.005em;
    max-inline-size: 18ch;
    margin: 0;
  }
  .intro {
    font-family: var(--ff-display);
    font-size: var(--fs-h3);
    color: var(--c-charcoal-soft);
    max-inline-size: var(--w-prose);
    margin-block-start: 1.4rem;
  }
</style>
