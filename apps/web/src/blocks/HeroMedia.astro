---
// Hero pleine page (home) — image de fond, haut flouté + dégradés pétrole, titre serif
// (texte simple OU mis en forme : citation italique), attribution plus petite, intro, bouton.
import { lexicalToInlineHtml, lexicalHasContent } from '../lib/lexical.js'
const { image = '/literature_cafe.jpg', eyebrow, heading, headingRich, attribution, intro, ctaLabel, ctaHref, lang = 'fr' } = Astro.props
const scroll = { fr: 'Défiler', es: 'Desplazar', en: 'Scroll', de: 'Scrollen' }[lang] ?? 'Défiler'
const headingHtml = lexicalHasContent(headingRich) ? lexicalToInlineHtml(headingRich) : null
---
<section class="hero">
  <img class="bg" src={image} alt="" aria-hidden="true" />
  <div class="grad"></div>
  <div class="blurtop" aria-hidden="true">
    <img src={image} alt="" />
    <div class="blurtop-grad"></div>
  </div>

  <div class="content" data-reveal>
    <div class="wrap">
      {eyebrow && <div class="eyebrow loc">{eyebrow}</div>}
      {headingHtml ? <h1 set:html={headingHtml} /> : heading && <h1>{heading}</h1>}
      {attribution && <p class="attribution">{attribution}</p>}
      <div class="row">
        {intro && <p class="intro">{intro}</p>}
        {ctaLabel && <a class="cta" href={ctaHref || '#'}>{ctaLabel}</a>}
      </div>
    </div>
  </div>

  <div class="scroll">{scroll}</div>
</section>

<style>
  .hero { position: relative; inline-size: 100%; block-size: 100vh; min-block-size: 660px; overflow: hidden; }
  .bg { position: absolute; inset: 0; inline-size: 100%; block-size: 100%; object-fit: cover; object-position: center 56%; }
  .grad {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, rgba(15,45,52,.66) 0%, rgba(15,45,52,.16) 20%, rgba(15,45,52,.06) 42%, rgba(15,45,52,.34) 72%, rgba(15,45,52,.74) 100%);
  }
  .blurtop {
    position: absolute; inset-block-start: 0; inset-inline: 0; block-size: 150px; overflow: hidden; pointer-events: none;
    -webkit-mask: linear-gradient(to bottom, #000 58%, transparent 100%);
    mask: linear-gradient(to bottom, #000 58%, transparent 100%);
  }
  .blurtop img {
    position: absolute; inset-block-start: 0; inset-inline-start: 0; inline-size: 100%; block-size: 100vh;
    object-fit: cover; object-position: center 56%;
    filter: blur(16px) brightness(.72) saturate(1.05); transform: scale(1.08);
  }
  .blurtop-grad { position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(15,45,52,.66), rgba(15,45,52,.3)); }

  .content { position: absolute; inset-inline: 0; inset-block-end: clamp(48px, 7vw, 104px); }
  .loc { letter-spacing: .24em; color: var(--c-gold-light); }
  .hero h1 {
    font-family: var(--ff-display); font-weight: 500; font-size: var(--fs-hero);
    line-height: .98; letter-spacing: -.005em; color: #F6F1E6;
    margin: .26em 0 0; max-inline-size: 17ch; text-wrap: balance;
  }
  .hero h1 :global(em) { font-style: italic; }
  .hero h1 :global(strong) { font-weight: 600; }
  .attribution {
    font-family: var(--ff-mono); font-size: 12px; letter-spacing: .18em; text-transform: uppercase;
    color: var(--c-gold-light); margin: 18px 0 0;
  }
  .row { display: flex; flex-wrap: wrap; align-items: center; gap: clamp(18px,3vw,40px); margin-block-start: clamp(22px,3vw,38px); max-inline-size: 760px; }
  .intro { font-size: 16.5px; line-height: 1.7; color: rgba(246,241,230,.86); margin: 0; max-inline-size: 46ch; white-space: pre-line; }
  .cta {
    display: inline-flex; align-items: center; gap: 12px; padding: 15px 26px;
    border: 1px solid rgba(216,190,138,.85); border-radius: 40px;
    font-family: var(--ff-mono); font-size: 11px; letter-spacing: .18em; text-transform: uppercase;
    color: #F6F1E6; white-space: nowrap; transition: background .4s, color .4s, border-color .4s;
  }
  .cta:hover { background: var(--c-gold-light); color: var(--c-petrol-deep); border-color: var(--c-gold-light); }

  .scroll {
    position: absolute; inset-inline-end: clamp(20px,4vw,56px); inset-block-end: clamp(20px,3vw,34px);
    font-family: var(--ff-mono); font-size: 10px; letter-spacing: .18em; text-transform: uppercase;
    color: rgba(246,241,230,.55); writing-mode: vertical-rl;
  }
  @media (max-width: 860px) { .hero { block-size: 92vh; } }
</style>
