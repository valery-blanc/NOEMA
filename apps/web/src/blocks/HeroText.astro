---
// Hero de page intérieure (sans image) — sur crème, dégage la hauteur de l'en-tête.
const { block } = Astro.props
---
<section class="herotext" data-reveal>
  <div class="wrap">
    {block.eyebrow && <div class="eyebrow">{block.eyebrow}</div>}
    {block.heading && <h1>{block.heading}</h1>}
    {block.intro && <p>{block.intro}</p>}
    {block.ctaLabel && block.ctaHref && <a class="cta" href={block.ctaHref}>{block.ctaLabel}</a>}
  </div>
</section>

<style>
  .herotext { padding-block: calc(var(--header-h) + clamp(48px,8vw,120px)) clamp(24px,4vw,48px); background: var(--c-cream); }
  .eyebrow { color: var(--c-gold-deep); }
  .herotext h1 { font-size: clamp(38px,6vw,88px); line-height: 1; color: var(--c-petrol-head); margin: .3em 0 0; max-inline-size: 18ch; }
  .herotext p { font-size: 16.5px; line-height: 1.7; color: var(--c-ink-soft); max-inline-size: 52ch; margin: 22px 0 0; }
  .cta {
    display: inline-flex; margin-block-start: 28px; padding: 14px 26px;
    border: 1px solid var(--c-gold-deep); border-radius: 40px;
    font-family: var(--ff-mono); font-size: 11px; letter-spacing: .18em; text-transform: uppercase; color: var(--c-petrol-head);
    transition: background .4s, color .4s;
  }
  .cta:hover { background: var(--c-petrol); color: var(--c-cream-text); border-color: var(--c-petrol); }
</style>
