---
import { fmtFolio } from '../lib/toc.js'

const { block, id, folio } = Astro.props
const entries = block.entries ?? []
---
<section class="section" id={id} data-section={folio ? id : undefined} data-reveal>
  <div class="folio" aria-hidden="true">{fmtFolio(folio)}</div>
  <div class="main">
    {block.sectionTitle && <h2>{block.sectionTitle}</h2>}
    <ol class="index">
      {entries.map((e, i) => (
        <li>
          <span class="num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
          <div class="entry">
            <h3>{e.label}</h3>
            {e.text && <p>{e.text}</p>}
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .index {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .index li {
    display: grid;
    grid-template-columns: 3rem 1fr;
    column-gap: var(--gutter);
    align-items: baseline;
    padding-block: clamp(1.2rem, 3vw, 2rem);
    border-block-start: 1px solid var(--c-brass);
  }
  .index li:last-child {
    border-block-end: 1px solid var(--c-brass);
  }
  .index .num {
    font-family: var(--ff-display);
    font-size: var(--fs-h3);
    color: var(--c-brass);
  }
  .index .entry h3 {
    font-size: var(--fs-h3);
    margin: 0 0 0.3em;
  }
  .index .entry p {
    margin: 0;
    color: var(--c-charcoal-soft);
    max-inline-size: var(--w-prose);
  }
</style>
