---
const { block } = Astro.props
---
<section class="pq" data-reveal>
  <div class="wrap">
    <blockquote>
      <p>{block.quote}</p>
      {block.attribution && <cite>{block.attribution}</cite>}
    </blockquote>
  </div>
</section>

<style>
  .pq { background: var(--c-cream); padding-block: clamp(48px,8vw,96px); }
  blockquote { margin: 0; max-inline-size: 34ch; margin-inline: auto; text-align: center; }
  blockquote p { font-family: var(--ff-display); font-size: clamp(28px,4vw,48px); line-height: 1.18; color: var(--c-petrol-head); margin: 0; }
  blockquote p::before { content: '“'; }
  blockquote p::after { content: '”'; }
  cite { display: block; margin-block-start: 1.2rem; font-style: normal; font-family: var(--ff-mono); text-transform: uppercase; letter-spacing: .18em; font-size: 11px; color: var(--c-gold-deep); }
</style>
