---
const { block } = Astro.props
const petrol = block.variant === 'petrol'
---
<section class={`pq ${petrol ? 'petrol' : 'cream'}`} data-reveal>
  <div class="wrap">
    <div class="mark" aria-hidden="true">“</div>
    <blockquote>
      <p>{block.quote}</p>
      {block.attribution && <cite>{block.attribution}</cite>}
    </blockquote>
  </div>
</section>

<style>
  .pq { padding-block: clamp(72px,11vw,150px); }
  .pq.cream { background: var(--c-cream); }
  .pq.petrol { background: var(--c-petrol-deep); color: var(--c-cream-text-2); }
  .wrap { max-inline-size: 1100px; text-align: center; }
  .mark { font-family: var(--ff-display); font-size: 60px; line-height: 0; height: 30px; color: rgba(201,168,106,.55); }
  blockquote { margin: 0; }
  blockquote p { font-family: var(--ff-display); font-weight: 500; font-size: clamp(28px,4vw,56px); line-height: 1.28; margin: 0; text-wrap: balance; }
  .cream blockquote p { color: var(--c-petrol-head); }
  .petrol blockquote p { color: #F6F1E6; }
  cite { display: block; margin-block-start: 28px; font-style: normal; font-family: var(--ff-mono); text-transform: uppercase; letter-spacing: .2em; font-size: 11px; color: var(--c-gold); }
</style>
