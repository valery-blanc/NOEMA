---
// Bande Services pétrole pleine largeur, 3 colonnes numérotées.
const { block } = Astro.props
const items = block.items ?? []
---
<section class="band">
  <div class="wrap">
    <div class="head">
      {block.eyebrow && <div class="eyebrow gold">{block.eyebrow}</div>}
      {block.heading && <h2>{block.heading}</h2>}
    </div>
    <div class="cols">
      {items.map((it, i) => (
        <div class="col" data-reveal style={`transition-delay:${i * 80}ms`}>
          <div class="num">{String(i + 1).padStart(2, '0')}</div>
          <div class="rule"></div>
          <h3>{it.title}</h3>
          {it.text && <p>{it.text}</p>}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .band { background: var(--c-petrol); color: var(--c-cream-text-2); padding-block: var(--pad-y); }
  .head { display: flex; justify-content: space-between; align-items: baseline; flex-wrap: wrap; gap: 16px; margin-block-end: clamp(36px,5vw,64px); }
  .eyebrow.gold { color: var(--c-gold-light); }
  .head h2 { font-size: var(--fs-h2); color: #F4EFE2; max-inline-size: 18ch; }
  .cols { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(24px,3.4vw,56px); }
  .num { font-family: var(--ff-mono); font-size: 12px; color: var(--c-gold-light); letter-spacing: .1em; }
  .rule { block-size: 1px; background: rgba(241,236,221,.2); margin-block: 16px 20px; }
  .col h3 { font-family: var(--ff-display); font-size: 28px; color: #F4EFE2; margin: 0 0 14px; }
  .col p { font-size: 14.5px; line-height: 1.72; color: rgba(241,236,221,.7); margin: 0; }
  @media (max-width: 860px) { .cols { grid-template-columns: 1fr; gap: 32px; } }
</style>
