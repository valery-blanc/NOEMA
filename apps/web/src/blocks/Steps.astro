---
const { block } = Astro.props
const items = block.items ?? []
---
<section class="steps">
  <div class="wrap">
    <div class="head">
      {block.eyebrow && <div class="eyebrow">{block.eyebrow}</div>}
      {block.heading && <h2>{block.heading}</h2>}
    </div>
    <div class="grid">
      {items.map((it, i) => (
        <div class="step" data-reveal style={`transition-delay:${i * 70}ms`}>
          <div class="num">{String(i + 1).padStart(2, '0')}</div>
          <div class="rule"></div>
          <h3>{it.title}</h3>
          {it.text && <p>{it.text}</p>}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .steps { background: var(--c-cream); padding-block: var(--pad-y); }
  .head { margin-block-end: clamp(36px,5vw,64px); }
  .eyebrow { color: var(--c-gold-deep); }
  .head h2 { font-size: var(--fs-h2); color: var(--c-petrol-head); margin: 14px 0 0; max-inline-size: 20ch; }
  .grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: clamp(24px,3vw,48px); }
  .num { font-family: var(--ff-mono); font-size: 12px; color: var(--c-gold-deep); letter-spacing: .1em; }
  .rule { block-size: 1px; background: var(--c-line); margin-block: 14px 18px; }
  .step h3 { font-family: var(--ff-display); font-size: 25px; color: var(--c-petrol-head); margin: 0 0 10px; }
  .step p { font-size: 14.5px; line-height: 1.7; color: var(--c-ink-soft); margin: 0; }
  @media (max-width: 860px) { .grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 520px) { .grid { grid-template-columns: 1fr; } }
</style>
