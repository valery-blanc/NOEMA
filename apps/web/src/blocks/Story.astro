---
import { lexicalToHtml } from '../lib/lexical.js'
const { block } = Astro.props
const html = block.body ? lexicalToHtml(block.body) : ''
---
<section class="story" data-reveal>
  <div class="wrap grid">
    <div class="aside">{block.eyebrow && <span class="eyebrow">{block.eyebrow}</span>}</div>
    <div class="col">
      {html && <div class="body" set:html={html} />}
      {block.signatureName && <div class="sig">{block.signatureName}</div>}
      {block.role && <div class="role">{block.role}</div>}
    </div>
  </div>
</section>

<style>
  .story { background: var(--c-cream); padding-block: clamp(64px,9vw,130px); }
  .grid { display: grid; grid-template-columns: .4fr .6fr; gap: clamp(28px,5vw,80px); align-items: start; }
  .eyebrow { color: var(--c-gold-deep); }
  .body :global(p) { font-size: 16.5px; line-height: 1.85; color: rgba(31,42,44,.82); margin: 0 0 20px; }
  .body :global(p:first-child) { font-family: var(--ff-display); font-size: clamp(22px,2.6vw,32px); line-height: 1.4; color: var(--c-petrol-head); margin-block-end: 26px; }
  .body :global(p:last-child) { margin-block-end: 0; }
  .sig { font-family: var(--ff-script); font-size: 50px; line-height: 1; color: #173A40; margin-block-start: 34px; }
  .role { font-family: var(--ff-mono); font-size: 11px; letter-spacing: .1em; text-transform: uppercase; color: var(--c-ink-mute); margin-block-start: 8px; }
  @media (max-width: 860px) { .grid { grid-template-columns: 1fr; gap: 16px; } }
</style>
