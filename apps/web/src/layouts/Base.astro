---
import '../styles/tokens.css'

const {
  lang = 'fr',
  currentSlug = 'accueil',
  isHome = false,
  title = 'NOÊMA',
  settings = null,
  navPages = [],
} = Astro.props

// RTL-first : direction dérivée de la langue (arabe/hébreu/farsi → rtl).
const RTL = ['ar', 'he', 'fa', 'ur']
const dir = RTL.includes(lang) ? 'rtl' : 'ltr'

const siteName = settings?.siteName ?? 'NOÊMA'
const contactEmail = settings?.contactEmail ?? ''
const LANGS = ['fr', 'es', 'en', 'de']

const pageHref = (slug) => (slug === 'accueil' ? `/${lang}/` : `/${lang}/${slug}/`)
const langHref = (loc) => (isHome || currentSlug === 'accueil' ? `/${loc}/` : `/${loc}/${currentSlug}/`)

// Sous-menus de DÉMONSTRATION (faux) — attachés à « services » pour visualiser le rendu.
// À brancher sur un vrai champ CMS (navChildren) plus tard.
const SUBNAV = {
  services: [
    { fr: 'Bibliothèques privées', es: 'Bibliotecas privadas', en: 'Private libraries', de: 'Privatbibliotheken' },
    { fr: 'Espaces culturels', es: 'Espacios culturales', en: 'Cultural spaces', de: 'Kulturräume' },
    { fr: 'Collections patrimoniales', es: 'Colecciones patrimoniales', en: 'Heritage collections', de: 'Sammlungen' },
  ],
}
const subnavFor = (slug) => (SUBNAV[slug] ?? []).map((o) => o[lang] ?? o.fr)
---
<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — {siteName}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Inter:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class={isHome ? 'is-home' : ''}>
    <header class="site-header" id="hdr">
      <div class="hdr-inner">
        <a class="wordmark" href={`/${lang}/`}>{siteName}</a>

        <nav class="topnav" aria-label="Navigation principale">
          <ul>
            {navPages.map((p) => {
              const sub = subnavFor(p.slug)
              return (
                <li class={sub.length ? 'has-sub' : ''}>
                  <a href={pageHref(p.slug)} class={p.slug === currentSlug ? 'on' : ''}>
                    <span class="txt">{p.title}</span>
                  </a>
                  {sub.length > 0 && (
                    <div class="submenu">
                      <ul>
                        {sub.map((label) => (
                          <li><a href={pageHref(p.slug)}><span class="txt">{label}</span></a></li>
                        ))}
                      </ul>
                    </div>
                  )}
                </li>
              )
            })}
          </ul>
        </nav>

        <div class="hdr-right">
          <div class="langs" aria-label="Langues">
            {LANGS.map((loc) => (
              <a href={langHref(loc)} class={loc === lang ? 'on' : ''} hreflang={loc}>{loc.toUpperCase()}</a>
            ))}
          </div>
          <button class="burger" type="button" aria-label="Menu" aria-expanded="false" data-nav-toggle>
            <span></span><span></span>
          </button>
        </div>
      </div>
    </header>

    <button class="scrim" type="button" aria-hidden="true" tabindex="-1" data-nav-close></button>

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="inner">
        <span class="fw">{siteName}</span>
        <nav class="fnav" aria-label="Pied de page">
          {navPages.map((p) => (<a href={pageHref(p.slug)}>{p.title}</a>))}
        </nav>
        {contactEmail && <a class="mail" href={`mailto:${contactEmail}`}>{contactEmail}</a>}
        <p class="legal">© {new Date().getFullYear()} {siteName} · Maison intellectuelle</p>
      </div>
    </footer>

    <script>
      const body = document.body
      const hdr = document.getElementById('hdr')

      // Menu mobile (off-canvas)
      const setNav = (open) => {
        body.classList.toggle('nav-open', open)
        document.querySelector('[data-nav-toggle]')?.setAttribute('aria-expanded', String(open))
      }
      document.querySelector('[data-nav-toggle]')?.addEventListener('click', () =>
        setNav(!body.classList.contains('nav-open')),
      )
      document.querySelector('[data-nav-close]')?.addEventListener('click', () => setNav(false))

      // En-tête : transparent au-dessus du hero (accueil), opaque au scroll
      const onScroll = () => hdr?.classList.toggle('scrolled', window.scrollY > 40)
      onScroll()
      window.addEventListener('scroll', onScroll, { passive: true })

      // Apparition au scroll (désactivée si l'utilisateur réduit les animations)
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches
      if (!reduce && 'IntersectionObserver' in window) {
        document.documentElement.classList.add('reveal-ready')
        const io = new IntersectionObserver(
          (entries, obs) => {
            entries.forEach((e) => {
              if (e.isIntersecting) { e.target.classList.add('is-in'); obs.unobserve(e.target) }
            })
          },
          { rootMargin: '0px 0px -10% 0px' },
        )
        document.querySelectorAll('[data-reveal]').forEach((el) => io.observe(el))
      }
    </script>

    <style is:global>
      /* ====== En-tête pleine largeur, sticky transparent → opaque ====== */
      .site-header {
        position: fixed;
        inset-block-start: 0;
        inset-inline: 0;
        z-index: 50;
        block-size: var(--header-h);
        display: flex;
        align-items: center;
        background: var(--c-ivory);
        border-block-end: 1px solid var(--c-brass);
        transition: background 300ms ease, border-color 300ms ease;
      }
      /* Accueil : transparent tant qu'on n'a pas scrollé (le haut du hero est fondu en beige) */
      body.is-home .site-header:not(.scrolled) {
        background: transparent;
        border-block-end-color: transparent;
      }
      .hdr-inner {
        inline-size: 100%;
        padding-inline: var(--pad-x);
        display: flex;
        align-items: center;
        gap: clamp(1rem, 3vw, 3rem);
      }
      .wordmark {
        font-family: var(--ff-display);
        font-size: 1.5rem;
        letter-spacing: 0.1em;
        text-decoration: none;
        color: var(--c-charcoal);
      }

      /* ====== Menu horizontal ====== */
      .topnav { margin-inline: auto; }
      .topnav > ul {
        list-style: none; margin: 0; padding: 0;
        display: flex; gap: clamp(1.2rem, 2.4vw, 2.6rem);
      }
      .topnav > ul > li { position: relative; }
      .topnav a {
        display: inline-block;
        text-decoration: none;
        color: var(--c-charcoal);
        font-size: var(--fs-small);
        letter-spacing: 0.12em;
        text-transform: uppercase;
        padding-block: 1.6rem;
      }
      .topnav a .txt { position: relative; }
      /* Le tiret qui barre les DERNIÈRES LETTRES du menu actif / survolé */
      .topnav a.on .txt::after,
      .topnav > ul > li > a:hover .txt::after,
      .topnav .has-sub:focus-within > a .txt::after {
        content: '';
        position: absolute;
        inset-inline-end: -0.05em;
        inset-block-end: 0.42em;
        inline-size: 0.95em;
        block-size: 1px;
        background: var(--c-charcoal);
      }

      /* ====== Sous-menu déroulant (style meghanmaven) ====== */
      .submenu {
        position: absolute;
        inset-block-start: 100%;
        inset-inline-start: 50%;
        transform: translateX(-50%) translateY(6px);
        min-inline-size: 16rem;
        background: var(--c-ivory);
        border: 1px solid var(--c-brass);
        padding: 0.6rem 0;
        opacity: 0;
        visibility: hidden;
        transition: opacity 220ms ease, transform 220ms ease;
      }
      [dir='rtl'] .submenu { transform: translateX(50%) translateY(6px); }
      .has-sub:hover .submenu,
      .has-sub:focus-within .submenu {
        opacity: 1; visibility: visible;
        transform: translateX(-50%) translateY(0);
      }
      [dir='rtl'] .has-sub:hover .submenu,
      [dir='rtl'] .has-sub:focus-within .submenu { transform: translateX(50%) translateY(0); }
      .submenu ul { list-style: none; margin: 0; padding: 0; }
      .submenu a {
        display: block;
        padding: 0.55rem 1.4rem;
        text-transform: none;
        letter-spacing: 0.02em;
        font-family: var(--ff-display);
        font-size: 1.15rem;
        color: var(--c-charcoal-soft);
      }
      .submenu a:hover .txt::after,
      .submenu a:focus .txt::after {
        content: '';
        position: absolute;
        inset-inline-end: -0.05em;
        inset-block-end: 0.35em;
        inline-size: 0.9em; block-size: 1px;
        background: var(--c-charcoal);
      }
      .submenu a:hover { color: var(--c-charcoal); }

      .hdr-right { display: flex; align-items: center; gap: 1.2rem; margin-inline-start: auto; }
      .langs { display: flex; gap: 0.7rem; font-size: var(--fs-small); letter-spacing: 0.08em; }
      .langs a { text-decoration: none; color: var(--c-charcoal-soft); }
      .langs a.on { color: var(--c-brass); font-weight: 500; }
      .burger { display: none; }

      /* ====== Contenu pleine largeur ====== */
      .site-main { inline-size: 100%; }
      /* Pages sans hero-média : on dégage la hauteur de l'en-tête fixe */
      body:not(.is-home) .site-main { padding-block-start: var(--header-h); }
      /* Blocs de contenu (hors hero-média full-bleed) : respiration horizontale */
      .site-main > :not(.hero-media) {
        padding-inline: var(--pad-x);
      }

      /* Grille de section : folio (marge) | lecture | note (marginalia) */
      .section {
        display: grid;
        grid-template-columns: [folio] var(--folio-w) [main] minmax(0, var(--w-prose)) [note] 1fr;
        column-gap: var(--gutter);
        align-items: start;
        margin-block: clamp(2.5rem, 6vw, 5rem);
      }
      .section > .folio {
        grid-column: folio;
        font-family: var(--ff-display);
        font-size: 1.6rem; color: var(--c-brass);
        font-variant-numeric: tabular-nums; padding-block-start: 0.2rem;
      }
      .section > .main { grid-column: main; min-inline-size: 0; }
      .section > .main h2 { font-size: var(--fs-h2); margin-block-end: 0.7em; }
      .section > .note {
        grid-column: note;
        font-size: var(--fs-small); line-height: 1.6; color: var(--c-charcoal-soft);
        border-inline-start: 1px solid var(--c-brass);
        padding-inline-start: 1rem; max-inline-size: 24ch;
      }

      .prose p { margin-block: 0 1.2em; max-inline-size: var(--w-prose); }
      .prose blockquote {
        margin-inline: 0; padding-inline-start: 1.2rem;
        border-inline-start: 2px solid var(--c-brass);
        font-family: var(--ff-display); font-size: var(--fs-h3); color: var(--c-charcoal-soft);
      }

      /* ====== Apparition au scroll ====== */
      html.reveal-ready [data-reveal] {
        opacity: 0; transform: translateY(var(--reveal-shift));
        transition: opacity 600ms ease, transform 600ms ease;
      }
      html.reveal-ready [data-reveal].is-in { opacity: 1; transform: none; }

      /* ====== Pied de page ====== */
      .site-footer { margin-block-start: clamp(4rem, 10vw, 9rem); background: var(--c-petrol-deep); color: var(--c-ivory); }
      .site-footer .inner {
        padding: clamp(2.5rem, 6vw, 4rem) var(--pad-x);
        display: flex; flex-direction: column; gap: 0.9rem;
      }
      .site-footer .fw { font-family: var(--ff-display); font-size: 1.4rem; letter-spacing: 0.06em; }
      .site-footer .fnav { display: flex; gap: 1.25rem; flex-wrap: wrap; }
      .site-footer a { color: var(--c-brass-soft); text-decoration: none; font-size: var(--fs-small); }
      .site-footer a:hover { color: var(--c-ivory); }
      .site-footer .legal { margin: 0; font-size: var(--fs-small); color: #9a958a; }

      .scrim { display: none; }

      /* ====== Mobile : menu plein écran ====== */
      @media (max-width: 860px) {
        .burger {
          display: grid; align-content: center; gap: 5px;
          inline-size: 2.2rem; block-size: 2.2rem;
          background: none; border: none; cursor: pointer; padding: 0;
        }
        .burger span { display: block; block-size: 1px; background: var(--c-charcoal); }
        .topnav {
          position: fixed; inset: 0;
          background: var(--c-ivory);
          margin: 0; padding: calc(var(--header-h) + 1rem) var(--pad-x) 2rem;
          transform: translateY(-100%);
          transition: transform 360ms ease;
          z-index: 45; overflow-y: auto;
        }
        body.nav-open .topnav { transform: none; }
        .topnav > ul { flex-direction: column; gap: 0.4rem; }
        .topnav a { font-size: 1rem; padding-block: 0.8rem; }
        .topnav .has-sub .submenu {
          position: static; transform: none; opacity: 1; visibility: visible;
          border: none; padding: 0 0 0.6rem 1rem; min-inline-size: 0;
        }
        .topnav .has-sub .submenu a { padding-inline: 0; }
        .section { grid-template-columns: 1fr; row-gap: 0.6rem; }
        .section > .note {
          border-inline-start: none; border-block-start: 1px solid var(--c-brass);
          padding-inline-start: 0; padding-block-start: 0.8rem; max-inline-size: none;
        }
      }
    </style>
  </body>
</html>
