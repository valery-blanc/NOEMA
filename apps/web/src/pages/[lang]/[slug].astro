---
import Base from '../../layouts/Base.astro'
import BlockList from '../../blocks/BlockList.astro'
import { getSiteSettings, getNavPages, getPageBySlug } from '../../lib/payload.js'

export async function getStaticPaths() {
  const LANGS = ['fr', 'es', 'en', 'de']
  let slugs = []
  try {
    const pages = await getNavPages('fr')
    slugs = pages.map((p) => p.slug).filter((s) => s && s !== 'accueil' && /^[a-z0-9-]+$/.test(s))
  } catch {
    slugs = []
  }
  const paths = []
  for (const lang of LANGS) for (const slug of slugs) paths.push({ params: { lang, slug } })
  return paths
}

const { lang, slug } = Astro.params

let settings = null
let navPages = []
let page = null
try {
  settings = await getSiteSettings(lang)
  navPages = await getNavPages(lang)
  page = await getPageBySlug(slug, lang)
} catch (e) {}

const blocks = page?.layout ?? []
const contactEmail = settings?.contactEmail ?? 'bonjour@noema.ch'
---
<Base lang={lang} currentSlug={slug} title={page?.title ?? slug} settings={settings} navPages={navPages}>
  <BlockList blocks={blocks} lang={lang} contactEmail={contactEmail} />
</Base>
