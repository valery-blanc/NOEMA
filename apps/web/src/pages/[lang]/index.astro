---
import Base from '../../layouts/Base.astro'
import { getSiteSettings, getNavPages, getPageBySlug } from '../../lib/payload.js'
import { lexicalToHtml } from '../../lib/lexical.js'

export function getStaticPaths() {
  return ['fr', 'es', 'en', 'de'].map((lang) => ({ params: { lang } }))
}

const { lang } = Astro.params

let settings = null
let navPages = []
let page = null
let cmsError = null
try {
  settings = await getSiteSettings(lang)
  navPages = await getNavPages(lang)
  page = await getPageBySlug('accueil', lang)
} catch (e) {
  cmsError = e instanceof Error ? e.message : String(e)
}

const tagline = settings?.tagline ?? ''
const siteName = settings?.siteName ?? 'NOÊMA'
const contentHtml = page?.content ? lexicalToHtml(page.content) : ''
---
<Base lang={lang} isHome={true} currentSlug="accueil" title={siteName} settings={settings} navPages={navPages}>
  <section class="hero">
    <h1>{siteName}</h1>
    {tagline && <p class="tagline">{tagline}</p>}
  </section>

  {page && (
    <article class="prose">
      <h2>{page.title}</h2>
      {page.excerpt && <p class="lead">{page.excerpt}</p>}
      <Fragment set:html={contentHtml} />
    </article>
  )}

  <p class="status">
    {cmsError ? `CMS injoignable : ${cmsError}` : 'Chaîne CMS → API → front : OK'}
  </p>
</Base>

<style>
  .hero {
    margin-block-end: clamp(2rem, 8vh, 5rem);
  }
  .hero h1 {
    font-size: var(--fs-display);
    letter-spacing: 0.01em;
    margin: 0;
  }
  .tagline {
    font-family: var(--ff-display);
    font-size: var(--fs-h3);
    color: var(--c-charcoal-soft);
    margin-block-start: 0.5rem;
  }
  .lead {
    font-family: var(--ff-display);
    font-size: var(--fs-h3);
    color: var(--c-charcoal-soft);
  }
  .status {
    margin-block-start: 3rem;
    font-size: var(--fs-small);
    color: var(--c-petrol);
  }
</style>
